# Vorlage für assets/mail.php. Datei nach .env kopieren und lokal befüllen
# (.env ist gitignored, landet nie im Repo).

# Lokal mit DDEV: Mailpit fängt SMTP intern ohne Auth/TLS ab.
SMTP_HOST=localhost
SMTP_AUTH=false
SMTP_SECURE=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_PORT=1025

# Produktion (z.B. Gmail SMTP, benötigt ein App-Passwort statt des normalen
# Google-Passworts): SMTP_HOST=smtp.gmail.com, SMTP_AUTH=true, SMTP_SECURE=tls,
# SMTP_USERNAME=<gmail-adresse>, SMTP_PASSWORD=<app-passwort>, SMTP_PORT=587

# Empfänger-Adresse für Formularanfragen
EMAIL=teddyklinikgiessen@gmail.com
